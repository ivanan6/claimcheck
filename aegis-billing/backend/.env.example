# Copy this file to .env and add your Gemini API key.
# You can get the key at https://aistudio.google.com/apikey (free tier).
GEMINI_API_KEY=

# Optional model (default gemini-2.0-flash, fast and available in the free tier)
AEGIS_MODEL=gemini-2.0-flash

# If true, agents do not call Gemini and use prepared mock responses instead.
# Useful for recording the Loom demo offline or when API access is unavailable.
MOCK_MODE=false

# CORS origin for the frontend (default: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173
