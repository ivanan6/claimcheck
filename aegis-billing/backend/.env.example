# Kopirajte ovaj fajl u .env i dodajte vas Gemini API kljuc.
# Kljuc dobijate na https://aistudio.google.com/apikey (besplatan tier).
GEMINI_API_KEY=AIzaSyB5H8OshoUdJaGcTE1RG2RyW_pjYymdxD8

# Opciono - model (default gemini-2.0-flash, brz i u free tier-u)
AEGIS_MODEL=gemini-2.0-flash

# Ako je true - agenti ne pozivaju Gemini vec koriste pripremljene mock odgovore.
# Korisno za snimanje Loom demoa offline ili ako iz nekog razloga nema pristupa API-ju.
MOCK_MODE=false

# CORS origin za frontend (default: http://localhost:5173)
FRONTEND_ORIGIN=http://localhost:5173
